{
  "name": "my-monorepo",
  "private": true,
  "packageManager": "pnpm@10.33.0+sha512.10568bb4a6afb58c9eb3630da90cc9516417abebd3fabbe6739f0ae795728da1491e9db5a544c76ad8eb7570f5c4bb3d6c637b2cb41bfdcdb47fa823c8649319",
  "scripts": {
    "preinstall": "node -e \"const ua=process.env.npm_config_user_agent||''; if(!ua.includes('pnpm')){console.error('❌ This repo uses pnpm. Please run: pnpm install'); process.exit(1)}\"",
    "docker:check": "node scripts/docker-check.mjs strict",
    "docker:warn": "node scripts/docker-check.mjs warn",
    "docker:cleanup": "node scripts/docker-check.mjs cleanup",
    "docker:cleanup:sudo": "sudo node scripts/docker-check.mjs cleanup",
    "compose": "node scripts/compose.mjs --help",
    "compose:dev": "node scripts/compose.mjs dev",
    "compose:dev:reload": "pnpm compose:dev down && pnpm compose:dev up",
    "compose:prod": "node scripts/compose.mjs prod",
    "favicons:web": "node scripts/generate-web-favicons.mjs",
    "dev": "turbo run dev",
    "build": "turbo run build",
    "typecheck": "turbo run typecheck",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "test:cov": "turbo run test:cov",
    "test:e2e": "turbo run test:e2e",
    "pgadmin": "ssh -N -L 5051:127.0.0.1:5050 -o ExitOnForwardFailure=yes -o ServerAliveInterval=30 mikrus-deploy"
  },
  "pnpm": {
    "overrides": {
      "test-exclude": "7.0.1"
    },
    "onlyBuiltDependencies": [
      "@nestjs/core",
      "@prisma/engines",
      "esbuild",
      "prisma",
      "unrs-resolver"
    ]
  },
  "devDependencies": {
    "@resvg/resvg-js": "^2.6.2",
    "png-to-ico": "^3.0.1",
    "postcss": "^8.5.8",
    "postcss-nesting": "^14.0.0",
    "turbo": "^2.9.1"
  }
}
