# Local production-like environment for infrastructure/compose/production.local.yml
#
# Copy to .env.prod.local and adjust as needed.

# Publish nginx on this host port.
APP_HTTP_PORT=8080

POSTGRES_USER=admin
POSTGRES_PASSWORD=password
POSTGRES_DB=monorepo_db

PGADMIN_DEFAULT_EMAIL=admin@example.com
PGADMIN_DEFAULT_PASSWORD=change-me
PGADMIN_PORT=5050

# Public base URL used by web build for canonical/OG metadata.
DEFAULT_SITE_URL=https://app.adamzagorski.pl

# In-compose connection string (host must be the service name: postgres)
DATABASE_URL=postgresql://admin:password@postgres:5432/monorepo_db?schema=public
